    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"\\n\",\n",
    "    \"# load simulation data for S4\\n\",\n",
    "    \"s4_path = '../model/results simulation/bridges_S4.csv'\\n\",\n",
    "    \"\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    df_s4 = pd.read_csv(s4_path)\\n\",\n",
    "    \"except FileNotFoundError:\\n\",\n",
    "    \"    raise FileNotFoundError(f\\\"Error: Could not find {s4_path}.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# calculate average delay and breakdowns\\n\",\n",
    "    \"delay_agg = df_s4.groupby(['bridge_id', 'bridge_name', 'road', 'condition', 'vulnerability_score', 'vuln_level']).agg(\\n\",\n",
    "    \"    avg_delay_min=('total_delay_min', 'mean'),\\n\",\n",
    "    \"    avg_breakdowns=('breakdown_count', 'mean'),\\n\",\n",
    "    \"    avg_trucks=('trucks_passed', 'mean')\\n\",\n",
    "    \").reset_index()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# top 10 bottlenecks by delay\\n\",\n",
    "    \"top_delays = delay_agg.sort_values(by='avg_delay_min', ascending=False).head(10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# compare\\n\",\n",
    "    \"plt.figure(figsize=(12, 6), facecolor='white')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# create labels for y-axis WITH ID to prevent merging identical names\\n\",\n",
    "    \"top_delays['label'] = top_delays['bridge_name'] + ' (' + top_delays['road'] + ' - ID: ' + top_delays['bridge_id'].astype(str) + ')'\\n\",\n",
    "    \"\\n\",\n",
    "    \"sns.barplot(\\n\",\n",
    "    \"    data=top_delays,\\n\",\n",
    "    \"    x='avg_delay_min',\\n\",\n",
    "    \"    y='label',\\n\",\n",
    "    \"    hue='vuln_level',\\n\",\n",
    "    \"    dodge=False,\\n\",\n",
    "    \"    palette={'High': '#e74c3c', 'Medium-High': '#e67e22', 'Medium-Low': '#f1c40f', 'Low': '#2ecc71'}\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.title('Top 10 Bridges Causing Most Delays in Disaster Scenario (S4)', fontsize=14, fontweight='bold', pad=15)\\n\",\n",
    "    \"plt.xlabel('Average Total Delay (Minutes)', fontsize=12)\\n\",\n",
    "    \"plt.ylabel('Bridge', fontsize=12)\\n\",\n",
    "    \"plt.grid(axis='x', linestyle='--', alpha=0.7)\\n\",\n",
    "    \"plt.legend(title='Vulnerability Level', loc='lower right')\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig('top_10_delays_S4.png', dpi=150, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nTOP 10 DELAYS (S4):\\\")\\n\",\n",
    "    \"display(top_delays[['bridge_id', 'road', 'bridge_name', 'vuln_level', 'avg_breakdowns', 'avg_delay_min', 'avg_trucks']])\"\n",
    "   ],\n",
