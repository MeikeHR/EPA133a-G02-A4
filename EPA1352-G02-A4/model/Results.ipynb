    "   \"source\": [\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"\\n\",\n",
    "    \"# load theory data\\n\",\n",
    "    \"theorie_path = '../data/new_data/roads_after_dataanalysis.csv'\\n\",\n",
    "    \"gdf_roads = pd.read_csv(theorie_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# load simulation data\\n\",\n",
    "    \"sim_path = '../model/results simulation/bridges_S0.csv'\\n\",\n",
    "    \"\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    df_sim = pd.read_csv(sim_path)\\n\",\n",
    "    \"except FileNotFoundError:\\n\",\n",
    "    \"    raise FileNotFoundError(f\\\"Error: Could not find {sim_path}.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# calculate average amount of trucks\\n\",\n",
    "    \"sim_agg = df_sim.groupby('bridge_id')['trucks_passed'].mean().reset_index()\\n\",\n",
    "    \"sim_agg.rename(columns={'trucks_passed': 'simulated_trucks'}, inplace=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# merging\\n\",\n",
    "    \"gdf_roads = gdf_roads.merge(sim_agg, left_on='id', right_on='bridge_id', how='left')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# filtering\\n\",\n",
    "    \"final_bridges = gdf_roads[gdf_roads['model_type'] == 'bridge'].copy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# compare\\n\",\n",
    "    \"plt.figure(figsize=(10, 7), facecolor='white')\\n\",\n",
    "    \"\\n\",\n",
    "    \"sns.scatterplot(\\n\",\n",
    "    \"    data=final_bridges,\\n\",\n",
    "    \"    x='vulnerability_score',\\n\",\n",
    "    \"    y='simulated_trucks',\\n\",\n",
    "    \"    hue='condition',\\n\",\n",
    "    \"    palette={'A': '#2ecc71', 'B': '#f1c40f', 'C': '#e67e22', 'D': '#e74c3c', 'Unknown': 'grey'},\\n\",\n",
    "    \"    s=80, alpha=0.7, edgecolor='black'\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# top 10 bottlenecks\\n\",\n",
    "    \"top_bottlenecks = final_bridges.sort_values(\\n\",\n",
    "    \"    by=['vulnerability_score', 'simulated_trucks'],\\n\",\n",
    "    \"    ascending=[False, False]\\n\",\n",
    "    \").head(10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.scatter(\\n\",\n",
    "    \"    top_bottlenecks['vulnerability_score'],\\n\",\n",
    "    \"    top_bottlenecks['simulated_trucks'],\\n\",\n",
    "    \"    color='none', edgecolor='red', linewidth=2, s=200, label='Top 10 Bottlenecks'\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"for _, row in top_bottlenecks.iterrows():\\n\",\n",
    "    \"    plt.annotate(\\n\",\n",
    "    \"        f\\\"{row['lrp']} ({row['road']})\\\",\\n\",\n",
    "    \"        (row['vulnerability_score'], row['simulated_trucks']),\\n\",\n",
    "    \"        xytext=(8, 5), textcoords='offset points', fontsize=8, fontweight='bold'\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.title('Simulation vs. Theory: Bridge Bottlenecks in Bangladesh', fontsize=14, fontweight='bold', pad=15)\\n\",\n",
    "    \"plt.xlabel('Theoretical Vulnerability Score (Condition * Hazard)', fontsize=12)\\n\",\n",
    "    \"plt.ylabel('Simulated Criticality (Avg. Trucks Passed)', fontsize=12)\\n\",\n",
    "    \"plt.grid(True, linestyle='--', alpha=0.5)\\n\",\n",
    "    \"plt.legend(title='Bridge Condition')\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig('simulation_vs_theory.png', dpi=150, bbox_inches='tight')\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nTOP 10 BOTTLENECKS:\\\")\\n\",\n",
    "    \"display(top_bottlenecks[['road', 'lrp', 'name', 'condition', 'vulnerability_score', 'simulated_trucks']])\"\n",
